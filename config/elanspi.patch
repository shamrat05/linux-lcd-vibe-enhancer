+	int src_width = self->sensor_width;
+	int src_height = self->sensor_height;
+	int out_width = src_width * 2;
+	int out_height = src_height * 2;
+	size_t frame_size = src_width * src_height;
+
+	int *temp_buffer = g_malloc(frame_size * sizeof(int));
+	int *temp_sorted = g_malloc(frame_size * sizeof(int));
+	int *src_pixels = g_malloc(frame_size * sizeof(int));
+
+	// Perform row-mean subtraction
+	for (int i = 0; i < src_height; ++i) {
+		int row_sum = 0;
+		for (int j = 0; j < src_width; ++j) {
+			row_sum += (int)data_in[i * src_width + j];
+		}
+		int row_mean = row_sum / src_width;
+		for (int j = 0; j < src_width; ++j) {
+			int val = (int)data_in[i * src_width + j] - row_mean;
+			temp_buffer[i * src_width + j] = val;
+		}
+	}
+
+	memcpy(temp_sorted, temp_buffer, frame_size * sizeof(int));
+	qsort(temp_sorted, frame_size, sizeof(int), cmp_int);
+
+	// 5% and 95% percentiles for clamping/stretching
+	int lvl_low = temp_sorted[frame_size * 5 / 100];
+	int lvl_high = temp_sorted[frame_size * 95 / 100];
+
+	// Scale and vertically flip to src_pixels
+	for (int i = 0; i < src_height; ++i) {
+		for (int j = 0; j < src_width; ++j) {
+			int px = temp_buffer[(src_height - i - 1) * src_width + j];
+			if (px < lvl_low) px = lvl_low;
+			if (px > lvl_high) px = lvl_high;
+			if (lvl_high > lvl_low)
+				px = (px - lvl_low) * 255 / (lvl_high - lvl_low);
+			else
+				px = 127;
+			src_pixels[i * src_width + j] = px;
 		}
 	}
+
+	// Bilinear upscaling to 192x192
+	for (int y = 0; y < out_height; ++y) {
+		for (int x = 0; x < out_width; ++x) {
+			int gx_fp = (x * (src_width - 1) * 65536) / (out_width - 1);
+			int gy_fp = (y * (src_height - 1) * 65536) / (out_height - 1);
+
+			int gxi = gx_fp >> 16;
+			int gyi = gy_fp >> 16;
+
+			int dx = gx_fp & 0xffff;
+			int dy = gy_fp & 0xffff;
+
+			int x1 = gxi + 1;
+			if (x1 >= src_width) x1 = src_width - 1;
+			int y1 = gyi + 1;
+			if (y1 >= src_height) y1 = src_height - 1;
+
+			int p00 = src_pixels[gyi * src_width + gxi];
+			int p10 = src_pixels[gyi * src_width + x1];
+			int p01 = src_pixels[y1 * src_width + gxi];
+			int p11 = src_pixels[y1 * src_width + x1];
+
+			gint64 val = (gint64)p00 * (65536 - dx) * (65536 - dy) +
+			              (gint64)p10 * dx * (65536 - dy) +
+			              (gint64)p01 * (65536 - dx) * dy +
+			              (gint64)p11 * dx * dy;
+			
+			int px = (int)(val >> 32);
+			if (px < 0) px = 0;
+			if (px > 255) px = 255;
+
+			data_out[y * out_width + x] = (guint8)px;
+		}
+	}
+
+	g_free(temp_buffer);
+	g_free(temp_sorted);
+	g_free(src_pixels);
 }
 
